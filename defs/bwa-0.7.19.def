BootStrap: yum
OSVersion: 9
MirrorURL: http://yum-repos.hpccluster/AlmaLinux/9/os/$basearch/
Include: yum

%post
mkdir -p /opt/software/
cd /opt/software/
dnf -y install epel-release
dnf -y install wget langpacks-en_GB.noarch tar 
dnf -y install make gcc git zlib-devel

git clone https://github.com/lh3/bwa --branch=v0.7.19
cd bwa
make

echo "export PATH=/opt/software/bwa/:$PATH" >> $SINGULARITY_ENVIRONMENT

